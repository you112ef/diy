# Environment Configuration for bolt.diy Mobile App

# API Configuration
# Production API (default)
API_BASE_URL=https://bolt.diy

# Development API (uncomment for local development)
# API_BASE_URL=http://localhost:5173

# Expo Configuration
EXPO_PUBLIC_API_BASE_URL=https://bolt.diy

# Push Notifications (Expo Push Service)
# These will be automatically configured by Expo
# EXPO_PUSH_TOKEN=ExponentPushToken[...]

# App Configuration
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_DEBUG_MODE=false

# Analytics (optional)
# ANALYTICS_ENABLED=false
# ANALYTICS_API_KEY=your_analytics_key

# Error Reporting (optional)
# SENTRY_DSN=your_sentry_dsn
# SENTRY_ENABLED=false

# Development Settings
# DEV_MENU_ENABLED=true
# FAST_REFRESH_ENABLED=true